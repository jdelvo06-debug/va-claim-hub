---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import NewsletterForm from '../components/NewsletterForm';
import FAQ from '../components/FAQ';

const conditions = await getCollection('conditions');
const featured = conditions
  .filter((c) => c.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const posts = await getCollection('blog', ({ data }) => !data.draft);
const recentPosts = posts
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);

const faqItems = [
  {
    question: 'What is a VA disability rating?',
    answer: 'A VA disability rating is a percentage (0% to 100%) assigned by the Department of Veterans Affairs that reflects the severity of your service-connected condition. This rating determines your monthly tax-free compensation. Ratings are assigned in increments of 10% and are based on specific criteria outlined in the VA Schedule for Rating Disabilities (VASRD).',
  },
  {
    question: 'How long does the VA disability claims process take?',
    answer: 'The average processing time for an initial VA disability claim is approximately 120-150 days, though this varies significantly. Claims with clear evidence and straightforward service connection may be resolved faster, while complex claims involving multiple conditions or requiring additional development can take longer. Fully Developed Claims (FDC) submitted with all evidence upfront tend to process faster than standard claims.',
  },
  {
    question: 'Can I file a VA claim years after leaving the military?',
    answer: 'Yes. There is no time limit for filing an initial VA disability claim. However, claims filed within one year of separation may receive an effective date back to the day after discharge, which means retroactive compensation. Claims filed later will typically have an effective date of the filing date. Regardless of when you separated, if you have a condition caused or worsened by service, you can and should file.',
  },
  {
    question: 'What is a nexus letter and do I need one?',
    answer: 'A nexus letter is a medical opinion from a qualified healthcare provider stating that your current condition is connected to your military service. It uses the phrase "at least as likely as not" to meet the VA\'s standard of proof. While not always required — particularly for conditions with strong in-service documentation — a nexus letter is often the deciding factor in claims where the connection is not immediately obvious.',
  },
  {
    question: 'What should I do if my VA claim is denied?',
    answer: 'You have several appeal options: (1) Supplemental Claim — submit new and relevant evidence, (2) Higher-Level Review — request a senior reviewer examine the same evidence, or (3) Board of Veterans Appeals — appeal to a Veterans Law Judge. The best option depends on why the claim was denied. If it was denied for lack of evidence, a Supplemental Claim with a strong nexus letter is often the most effective path.',
  },
];

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'VA Claim Hub',
  url: 'https://vaclaimhub.com',
  description: 'Free VA disability claim resources for veterans — condition guides, rating tips, nexus letter info, and C&P exam preparation.',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://vaclaimhub.com/conditions?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};

const faqStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<BaseLayout
  title="VA Disability Claim Resources | Rating Guides & Tips — VA Claim Hub"
  description="Free VA disability claim guides for veterans. Browse conditions, learn about nexus letters, prepare for C&P exams, and access DBQ resources to maximize your rating."
  structuredData={structuredData}
  tags={['VA disability claim', 'VA rating', 'veterans disability', 'nexus letter', 'C&P exam']}
>
  <!-- Hero Section — Split Layout -->
  <section class="relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-sm font-medium text-emerald-700 tracking-wide uppercase mb-4">
            For Veterans, By Veterans
          </p>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tighter leading-none text-zinc-900 mb-6">
            Navigate your VA disability claim with confidence
          </h1>
          <p class="text-lg text-zinc-600 leading-relaxed max-w-[52ch] mb-8">
            Condition-specific guides, rating criteria breakdowns, nexus letter templates, and C&P exam prep — everything you need to file a successful claim or appeal.
          </p>
          <div class="flex flex-col sm:flex-row gap-3">
            <a
              href="/conditions"
              class="inline-flex items-center justify-center px-6 py-3.5 text-sm font-medium text-white bg-emerald-700 rounded-xl hover:bg-emerald-800 active:scale-[0.98] transition-all"
            >
              Browse Conditions
            </a>
            <a
              href="/nexus-letters"
              class="inline-flex items-center justify-center px-6 py-3.5 text-sm font-medium text-zinc-700 bg-zinc-100 rounded-xl hover:bg-zinc-200 active:scale-[0.98] transition-all"
            >
              Nexus Letter Guide
            </a>
          </div>
        </div>

        <div class="hidden lg:block">
          <div class="relative">
            <div class="bg-zinc-100 rounded-2xl p-8 border border-zinc-200">
              <div class="space-y-4">
                <div class="flex items-center gap-3 text-sm text-zinc-600">
                  <div class="w-2 h-2 rounded-full bg-emerald-500"></div>
                  <span>Updated rating criteria for 2026</span>
                </div>
                <div class="grid grid-cols-2 gap-3">
                  {featured.slice(0, 4).map((condition) => (
                    <a
                      href={`/conditions/${condition.id}`}
                      class="p-4 rounded-xl bg-white border border-zinc-100 hover:border-emerald-200 hover:shadow-sm transition-all group"
                    >
                      <p class="text-sm font-medium text-zinc-900 group-hover:text-emerald-700 transition-colors">
                        {condition.data.title.split('(')[0].trim()}
                      </p>
                      <p class="text-xs text-zinc-400 mt-1">
                        {condition.data.commonRatings.join(' / ')}
                      </p>
                    </a>
                  ))}
                </div>
                <p class="text-xs text-zinc-400 text-center pt-2">
                  {conditions.length} conditions covered
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Conditions -->
  <section class="border-t border-zinc-200 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <div class="flex items-end justify-between mb-10">
        <div>
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-zinc-900">
            Most Claimed Conditions
          </h2>
          <p class="text-zinc-500 mt-2 max-w-[50ch]">
            Detailed rating guides for the conditions veterans file most frequently.
          </p>
        </div>
        <a href="/conditions" class="hidden sm:inline-flex text-sm font-medium text-emerald-700 hover:text-emerald-800 transition-colors">
          View all conditions &rarr;
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-zinc-200 rounded-2xl overflow-hidden border border-zinc-200">
        {featured.map((condition) => (
          <a
            href={`/conditions/${condition.id}`}
            class="p-6 bg-white hover:bg-zinc-50/80 transition-colors group"
          >
            <div class="flex items-start justify-between">
              <div>
                <p class="text-xs font-medium text-emerald-700 uppercase tracking-wider mb-2">
                  {condition.data.category.replace('-', ' ')}
                </p>
                <h3 class="text-lg font-semibold text-zinc-900 group-hover:text-emerald-700 transition-colors">
                  {condition.data.title}
                </h3>
                <p class="text-sm text-zinc-500 mt-1.5 max-w-[45ch] leading-relaxed">
                  {condition.data.description}
                </p>
              </div>
              <svg class="w-5 h-5 text-zinc-300 group-hover:text-emerald-600 transition-colors shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
              </svg>
            </div>
            <div class="flex gap-2 mt-4">
              {condition.data.commonRatings.map((rating: string) => (
                <span class="inline-flex px-2 py-0.5 text-xs font-mono font-medium text-zinc-500 bg-zinc-100 rounded">
                  {rating}
                </span>
              ))}
            </div>
          </a>
        ))}
      </div>

      <a href="/conditions" class="sm:hidden inline-flex text-sm font-medium text-emerald-700 hover:text-emerald-800 mt-6 transition-colors">
        View all conditions &rarr;
      </a>
    </div>
  </section>

  <!-- Resource Pillars -->
  <section class="border-t border-zinc-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-zinc-900 mb-10">
        Claim Resources
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <a href="/nexus-letters" class="group p-6 rounded-2xl border border-zinc-200 hover:border-emerald-200 bg-white hover:shadow-sm transition-all">
          <div class="w-10 h-10 rounded-lg bg-emerald-50 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-emerald-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-zinc-900 group-hover:text-emerald-700 transition-colors">Nexus Letters</h3>
          <p class="text-sm text-zinc-500 mt-2 leading-relaxed">
            What they are, who writes them, what language the VA requires, and how to get one that supports your claim.
          </p>
        </a>

        <a href="/cp-exam-prep" class="group p-6 rounded-2xl border border-zinc-200 hover:border-emerald-200 bg-white hover:shadow-sm transition-all">
          <div class="w-10 h-10 rounded-lg bg-emerald-50 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-emerald-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15a2.25 2.25 0 012.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-zinc-900 group-hover:text-emerald-700 transition-colors">C&P Exam Prep</h3>
          <p class="text-sm text-zinc-500 mt-2 leading-relaxed">
            How to prepare for your Compensation & Pension exam, what the examiner evaluates, and critical mistakes to avoid.
          </p>
        </a>

        <a href="/dbq-resources" class="group p-6 rounded-2xl border border-zinc-200 hover:border-emerald-200 bg-white hover:shadow-sm transition-all">
          <div class="w-10 h-10 rounded-lg bg-emerald-50 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-emerald-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.375 19.5h17.25m-17.25 0a1.125 1.125 0 01-1.125-1.125M3.375 19.5h7.5c.621 0 1.125-.504 1.125-1.125m-9.75 0V5.625m0 12.75v-1.5c0-.621.504-1.125 1.125-1.125m18.375 2.625V5.625m0 12.75c0 .621-.504 1.125-1.125 1.125m1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125m0 3.75h-7.5A1.125 1.125 0 0112 18.375m9.75-12.75c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125m19.5 0v1.5c0 .621-.504 1.125-1.125 1.125M2.25 5.625v1.5c0 .621.504 1.125 1.125 1.125m0 0h17.25m-17.25 0h7.5c.621 0 1.125.504 1.125 1.125M3.375 8.25c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125m17.25-3.75h-7.5c-.621 0-1.125.504-1.125 1.125m8.625-1.125c.621 0 1.125.504 1.125 1.125v1.5c0 .621-.504 1.125-1.125 1.125m-17.25 0h7.5m-7.5 0c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125M12 10.875v-1.5m0 1.5c0 .621-.504 1.125-1.125 1.125M12 10.875c0 .621.504 1.125 1.125 1.125m-2.25 0c.621 0 1.125.504 1.125 1.125M13.125 12h7.5m-7.5 0c-.621 0-1.125.504-1.125 1.125M20.625 12c.621 0 1.125.504 1.125 1.125v1.5c0 .621-.504 1.125-1.125 1.125m-17.25 0h7.5M12 14.625v-1.5m0 1.5c0 .621-.504 1.125-1.125 1.125M12 14.625c0 .621.504 1.125 1.125 1.125m-2.25 0c.621 0 1.125.504 1.125 1.125m0 0v.75" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-zinc-900 group-hover:text-emerald-700 transition-colors">DBQ Resources</h3>
          <p class="text-sm text-zinc-500 mt-2 leading-relaxed">
            Disability Benefits Questionnaires explained — which DBQ applies to your condition and how your doctor should complete it.
          </p>
        </a>

        <a href="/combined-ratings-calculator" class="group p-6 rounded-2xl border border-zinc-200 hover:border-emerald-200 bg-white hover:shadow-sm transition-all">
          <div class="w-10 h-10 rounded-lg bg-emerald-50 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-emerald-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 15.75V18m-7.5-6.75h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25V13.5zm0 2.25h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25V18zm2.498-6.75h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007V13.5zm0 2.25h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007V18zm2.504-6.75h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V13.5zm0 2.25h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V18zm2.498-6.75h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V13.5zM8.25 6h7.5v2.25h-7.5V6zM12 2.25c-1.892 0-3.758.11-5.593.322C5.307 2.7 4.5 3.652 4.5 4.756V19.5a2.25 2.25 0 002.25 2.25h10.5a2.25 2.25 0 002.25-2.25V4.756c0-1.104-.807-2.057-1.907-2.184A48.507 48.507 0 0012 2.25z" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-zinc-900 group-hover:text-emerald-700 transition-colors">Combined Ratings Calculator</h3>
          <p class="text-sm text-zinc-500 mt-2 leading-relaxed">
            VA ratings aren't added together. Use our calculator to see your true combined rating and estimated monthly compensation.
          </p>
        </a>

        <a href="/community-resources" class="group p-6 rounded-2xl border border-zinc-200 hover:border-emerald-200 bg-white hover:shadow-sm transition-all">
          <div class="w-10 h-10 rounded-lg bg-emerald-50 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-emerald-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-zinc-900 group-hover:text-emerald-700 transition-colors">Community Resources</h3>
          <p class="text-sm text-zinc-500 mt-2 leading-relaxed">
            Veteran-submitted nexus letter services, tools, and guides — reviewed and approved before listing.
          </p>
        </a>
      </div>
    </div>
  </section>

  <!-- Recent Articles -->
  <section class="border-t border-zinc-200 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <div class="flex items-end justify-between mb-10">
        <div>
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-zinc-900">Latest Articles</h2>
          <p class="text-zinc-500 mt-2">Strategies and guides for a stronger VA claim.</p>
        </div>
        <a href="/blog" class="hidden sm:inline-flex text-sm font-medium text-emerald-700 hover:text-emerald-800 transition-colors">
          All articles &rarr;
        </a>
      </div>

      <div class="divide-y divide-zinc-100">
        {recentPosts.map((post) => (
          <a href={`/blog/${post.id}`} class="group flex flex-col sm:flex-row sm:items-center justify-between py-5 gap-2">
            <div>
              <h3 class="text-base font-medium text-zinc-900 group-hover:text-emerald-700 transition-colors">
                {post.data.title}
              </h3>
              <p class="text-sm text-zinc-500 mt-1 max-w-[55ch]">{post.data.description}</p>
            </div>
            <time class="text-xs font-mono text-zinc-400 shrink-0" datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
            </time>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="border-t border-zinc-200">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-zinc-900 mb-2">Frequently Asked Questions</h2>
      <p class="text-zinc-500 mb-10">Common questions about the VA disability claims process.</p>
      <FAQ client:visible items={faqItems} />
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(faqStructuredData)} />

  <!-- CTA Section -->
  <section class="border-t border-zinc-200 bg-zinc-900">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-white mb-4">
        Know a resource that should be listed here?
      </h2>
      <p class="text-zinc-400 mb-8 max-w-[45ch] mx-auto">
        Help fellow veterans by submitting helpful links, tools, and guides. Every submission is reviewed before publishing.
      </p>
      <a
        href="/submit-resource"
        class="inline-flex items-center justify-center px-6 py-3.5 text-sm font-medium text-zinc-900 bg-white rounded-xl hover:bg-zinc-100 active:scale-[0.98] transition-all"
      >
        Submit a Resource
      </a>
    </div>
  </section>
</BaseLayout>
