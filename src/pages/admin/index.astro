---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import AdminDashboard from '../../components/admin/AdminDashboard';
---

<BaseLayout title="Admin Dashboard — VA Claim Hub" description="Site administration" noindex={true}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold tracking-tight text-zinc-900">Admin Dashboard</h1>
        <p class="text-sm text-zinc-500 mt-1">Manage resource submissions and newsletter subscribers.</p>
      </div>
      <a
        href="/admin/logout"
        class="px-4 py-2 text-sm text-zinc-500 hover:text-zinc-700 transition-colors"
      >
        Logout
      </a>
    </div>
    <AdminDashboard client:load />
  </div>
</BaseLayout>
