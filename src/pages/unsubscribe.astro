---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';

const url = Astro.url;
const success = url.searchParams.get('success') === '1';
const error = url.searchParams.get('error');

let errorMessage = '';
if (error === 'missing') {
  errorMessage = 'No unsubscribe token was provided. Please use the link from your newsletter email.';
} else if (error === 'invalid') {
  errorMessage = 'This unsubscribe link is invalid or has already been used.';
} else if (error === 'server') {
  errorMessage = 'An error occurred. Please try again or contact us directly.';
}
---

<BaseLayout
  title="Unsubscribe — VA Claim Hub"
  description="Unsubscribe from the VA Claim Hub newsletter."
  noindex={true}
>
  <section class="max-w-md mx-auto px-4 sm:px-6 py-24 text-center">
    {success ? (
      <div>
        <div class="w-14 h-14 rounded-full bg-emerald-50 flex items-center justify-center mx-auto mb-6">
          <svg class="w-7 h-7 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h1 class="text-2xl font-bold tracking-tight text-zinc-900 mb-3">You've been unsubscribed</h1>
        <p class="text-zinc-500 leading-relaxed">
          Your email has been removed from the VA Claim Hub newsletter. You won't receive any further emails from us.
        </p>
        <a
          href="/"
          class="inline-flex items-center justify-center mt-8 px-5 py-2.5 text-sm font-medium text-white bg-emerald-700 rounded-lg hover:bg-emerald-800 transition-all"
        >
          Back to VA Claim Hub
        </a>
      </div>
    ) : errorMessage ? (
      <div>
        <div class="w-14 h-14 rounded-full bg-red-50 flex items-center justify-center mx-auto mb-6">
          <svg class="w-7 h-7 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
          </svg>
        </div>
        <h1 class="text-2xl font-bold tracking-tight text-zinc-900 mb-3">Unsubscribe failed</h1>
        <p class="text-zinc-500 leading-relaxed">{errorMessage}</p>
        <a
          href="/contact"
          class="inline-flex items-center justify-center mt-8 px-5 py-2.5 text-sm font-medium text-white bg-emerald-700 rounded-lg hover:bg-emerald-800 transition-all"
        >
          Contact Us
        </a>
      </div>
    ) : (
      <div>
        <h1 class="text-2xl font-bold tracking-tight text-zinc-900 mb-3">Unsubscribe</h1>
        <p class="text-zinc-500 leading-relaxed">
          To unsubscribe from the VA Claim Hub newsletter, please use the unsubscribe link included in your newsletter email.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center justify-center mt-8 px-5 py-2.5 text-sm font-medium text-zinc-700 bg-zinc-100 rounded-lg hover:bg-zinc-200 transition-all"
        >
          Contact Us
        </a>
      </div>
    )}
  </section>
</BaseLayout>
