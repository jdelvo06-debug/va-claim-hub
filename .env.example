# Admin authentication
# Used in src/middleware.ts to protect /admin routes and in src/pages/admin/login.astro
# Set this to a long, random secret string
ADMIN_SECRET=your_admin_secret_here

# Turso / LibSQL database credentials
# Used in src/lib/db.ts to initialize the Drizzle ORM client
# Get your database URL and auth token from https://turso.tech
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here
